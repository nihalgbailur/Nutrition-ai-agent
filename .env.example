# --- Production (deploy later) ---
# XAI_API_KEY=your_xai_api_key_here
# LITELLM_MODEL=xai/grok-beta

# --- Local dev with Ollama (default when XAI key is unset) ---
# Ollama must be running: `ollama serve` (or Ollama app)
OLLAMA_HOST=http://127.0.0.1:11434
# Optional: pin a model (otherwise first model from `ollama list` is used)
OLLAMA_MODEL=llama3.2:3b

# Speed tuning (chat)
CHAT_MAX_TOKENS=280
CHAT_TIMEOUT_SECONDS=50

# Or force any LiteLLM provider:
# LITELLM_MODEL=ollama/qwen2.5-coder:3b

# Alternative cloud providers:
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Premium frontend (FastAPI + Next.js) ---
# API_PORT=8000
# Run backend: uv run uvicorn src.nutriplan.api.main:app --reload --port 8000
# Then cd frontend && npm run dev (dev proxy or NEXT_PUBLIC_API_URL=http://localhost:8000)
