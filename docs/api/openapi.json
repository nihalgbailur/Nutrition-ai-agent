            "type": "string",
            "title": "Id"
          },
          "recipe_id": {
            "type": "string",
            "title": "Recipe Id"
          },
          "recipe_name": {
            "type": "string",
            "title": "Recipe Name"
          },
          "rating": {
            "type": "integer",
