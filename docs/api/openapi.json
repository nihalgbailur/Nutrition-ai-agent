        "type": "object",
        "required": [
          "day_index",
          "day_label"
        ],
        "title": "DayMeals"
      },
      "DietStyle": {
        "type": "string",
        "enum": [
          "vegetarian",
          "vegan",
          "eggetarian",
          "non_veg",
          "jain"
