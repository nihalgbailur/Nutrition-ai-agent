          "maintenance",
          "energy",
          "general_health"
        ],
        "title": "HealthGoal"
      },
      "IngredientLine": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "quantity": {
            "type": "string",
            "title": "Quantity",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "name"
        ],
        "title": "IngredientLine"
